---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import CountryBadge from '@components/directory/CountryBadge.astro';
import FeatureBadge from '@components/directory/FeatureBadge.astro';

export async function getStaticPaths() {
  const shops = await getCollection('shops');
  return shops.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const location = [d.city, d.stateProvince, d.country].filter(Boolean).join(', ');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportingGoodsStore',
  name: d.name,
  description: d.description,
  ...(d.address && { address: { '@type': 'PostalAddress', streetAddress: d.address } }),
  ...(d.website && { url: d.website }),
  ...(d.phone && { telephone: d.phone }),
  ...(d.instagram && { sameAs: [`https://instagram.com/${d.instagram}`] }),
};
---
<BaseLayout
  title={`${d.name}, ${d.city} | Local Shops`}
  description={`${d.name} in ${location}. ${d.description.slice(0, 120)}…`}
  type="place"
  structuredData={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pb-16">
    <Breadcrumb crumbs={[
      { label: 'Directory', href: '/directory' },
      { label: 'Local Shops', href: '/directory/shops' },
      { label: d.name, href: `/directory/shops/${entry.id}` },
    ]} />

    {d.heroImage && (
      <img src={d.heroImage} alt={d.heroImageAlt ?? d.name}
        class="w-full h-64 sm:h-80 object-cover rounded-xl mb-6"
        loading="eager" width="800" height="320" />
    )}

    <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-3xl sm:text-4xl font-display text-concrete-900">{d.name}</h1>
        <p class="text-concrete-500 mt-1">{location}</p>
      </div>
      <CountryBadge country={d.country} />
    </div>

    {d.adultsWelcomeNote && (
      <blockquote class="border-l-4 border-skate-green pl-4 py-1 mb-6 text-concrete-600 italic">
        {d.adultsWelcomeNote}
      </blockquote>
    )}

    <div class="mb-6">
      <h2 class="font-display text-lg text-concrete-800 mb-3">Services</h2>
      <div class="flex flex-wrap gap-2">
        {d.servicesOffered.map((s) => <FeatureBadge label={s} variant="service" />)}
        {d.hasOnlineShop && <FeatureBadge label="Online Shop" variant="default" />}
      </div>
    </div>

    <div class="prose prose-concrete max-w-none mb-8">
      <p>{d.description}</p>
      <Content />
    </div>

    <div class="flex flex-wrap gap-3 pt-6 border-t border-concrete-200">
      {d.website && (
        <a href={d.website} target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-skate-orange text-white rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity no-underline min-h-0">
          Visit Website ↗
        </a>
      )}
      {d.instagram && (
        <a href={`https://instagram.com/${d.instagram}`} target="_blank" rel="noopener noreferrer" class="px-4 py-2 border border-concrete-300 text-concrete-600 rounded-lg text-sm font-medium hover:border-concrete-400 transition-colors no-underline min-h-0">
          @{d.instagram}
        </a>
      )}
      {d.phone && (
        <a href={`tel:${d.phone}`} class="px-4 py-2 border border-concrete-300 text-concrete-600 rounded-lg text-sm font-medium no-underline min-h-0">
          {d.phone}
        </a>
      )}
      <a href="/directory/shops" class="px-4 py-2 text-concrete-500 text-sm hover:text-concrete-700 transition-colors no-underline min-h-0 flex items-center">
        ← All shops
      </a>
    </div>
  </div>
</BaseLayout>
