---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import CountryBadge from '@components/directory/CountryBadge.astro';
import FeatureBadge from '@components/directory/FeatureBadge.astro';

export async function getStaticPaths() {
  const parks = await getCollection('parks');
  return parks.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const location = [d.city, d.stateProvince, d.country].filter(Boolean).join(', ');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsActivityLocation',
  name: d.name,
  description: d.description,
  ...(d.address && { address: { '@type': 'PostalAddress', streetAddress: d.address } }),
  ...(d.coordinates && { geo: { '@type': 'GeoCoordinates', latitude: d.coordinates.lat, longitude: d.coordinates.lng } }),
  ...(d.website && { url: d.website }),
  ...(d.openingHours && { openingHoursSpecification: d.openingHours }),
  publicAccess: true,
  amenityFeature: d.features.map((f) => ({ '@type': 'LocationFeatureSpecification', name: f, value: true })),
};
---
<BaseLayout
  title={`${d.name}, ${d.city} | Skate Parks`}
  description={`${d.name} in ${location}. ${d.description.slice(0, 120)}…`}
  type="place"
  structuredData={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pb-16">
    <Breadcrumb crumbs={[
      { label: 'Directory', href: '/directory' },
      { label: 'Skate Parks', href: '/directory/parks' },
      { label: d.name, href: `/directory/parks/${entry.id}` },
    ]} />

    {d.heroImage && (
      <img
        src={d.heroImage}
        alt={d.heroImageAlt ?? d.name}
        class="w-full h-64 sm:h-80 object-cover rounded-xl mb-6"
        loading="eager"
        width="800"
        height="320"
      />
    )}

    <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
      <div>
        <h1 class="text-3xl sm:text-4xl font-display text-concrete-900">{d.name}</h1>
        <p class="text-concrete-500 mt-1">{location}</p>
      </div>
      <CountryBadge country={d.country} />
    </div>

    <!-- Badges -->
    <div class="flex flex-wrap gap-2 mb-6">
      <FeatureBadge label={d.difficulty} variant="difficulty" />
      {d.adultFriendly && (
        <span class="flex items-center gap-1 px-3 py-1 text-sm rounded-full bg-green-50 text-skate-green border border-green-200 font-medium">
          ✓ Adult Friendly
        </span>
      )}
      {d.isIndoor && <span class="px-3 py-1 text-sm rounded-full bg-concrete-100 text-concrete-600 border border-concrete-200">Indoor</span>}
      {d.surface.map((s) => <FeatureBadge label={s} variant="surface" />)}
    </div>

    <!-- Details grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 bg-concrete-50 rounded-xl p-5 border border-concrete-200">
      {d.openingHours && (
        <div>
          <dt class="text-xs text-concrete-400 uppercase tracking-wide">Hours</dt>
          <dd class="text-sm text-concrete-700 mt-0.5">{d.openingHours}</dd>
        </div>
      )}
      {d.entryFee && (
        <div>
          <dt class="text-xs text-concrete-400 uppercase tracking-wide">Entry</dt>
          <dd class="text-sm text-concrete-700 mt-0.5">{d.entryFee}</dd>
        </div>
      )}
      {d.address && (
        <div>
          <dt class="text-xs text-concrete-400 uppercase tracking-wide">Address</dt>
          <dd class="text-sm text-concrete-700 mt-0.5">{d.address}</dd>
        </div>
      )}
      <div>
        <dt class="text-xs text-concrete-400 uppercase tracking-wide">Facilities</dt>
        <dd class="text-sm text-concrete-700 mt-0.5 flex flex-wrap gap-2">
          {d.hasLighting  !== undefined && <span>{d.hasLighting  ? '✓' : '✗'} Lighting</span>}
          {d.hasParking   !== undefined && <span>{d.hasParking   ? '✓' : '✗'} Parking</span>}
          {d.hasToilets   !== undefined && <span>{d.hasToilets   ? '✓' : '✗'} Toilets</span>}
          {d.isCovered    !== undefined && <span>{d.isCovered    ? '✓' : '✗'} Covered</span>}
        </dd>
      </div>
    </div>

    <!-- Features -->
    <div class="mb-8">
      <h2 class="font-display text-lg text-concrete-800 mb-3">Terrain &amp; Features</h2>
      <div class="flex flex-wrap gap-2">
        {d.features.map((f) => <FeatureBadge label={f} />)}
      </div>
    </div>

    <!-- Description + body content -->
    <div class="prose prose-concrete max-w-none mb-8">
      <p>{d.description}</p>
      <Content />
    </div>

    <!-- External links -->
    <div class="flex flex-wrap gap-3 pt-6 border-t border-concrete-200">
      {d.website && (
        <a href={d.website} target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-skate-orange text-white rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity no-underline min-h-0">
          Official Website ↗
        </a>
      )}
      {d.googleMapsUrl && (
        <a href={d.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="px-4 py-2 border border-concrete-300 text-concrete-600 rounded-lg text-sm font-medium hover:border-concrete-400 transition-colors no-underline min-h-0">
          Google Maps ↗
        </a>
      )}
      <a href="/directory/parks" class="px-4 py-2 text-concrete-500 text-sm hover:text-concrete-700 transition-colors no-underline min-h-0 flex items-center">
        ← All parks
      </a>
    </div>
  </div>
</BaseLayout>
