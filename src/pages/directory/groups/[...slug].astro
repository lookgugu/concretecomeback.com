---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import CountryBadge from '@components/directory/CountryBadge.astro';
import FeatureBadge from '@components/directory/FeatureBadge.astro';

export async function getStaticPaths() {
  const groups = await getCollection('groups');
  return groups.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const location = d.isOnline ? 'Online' : [d.city, d.stateProvince, d.country].filter(Boolean).join(', ');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: d.name,
  description: d.description,
  ...(d.website && { url: d.website }),
  ...(d.contactEmail && { contactPoint: { '@type': 'ContactPoint', email: d.contactEmail } }),
  sameAs: [d.facebook, d.discord, d.reddit, d.instagram ? `https://instagram.com/${d.instagram}` : undefined].filter(Boolean),
};
---
<BaseLayout
  title={`${d.name} | Adult Skating Groups`}
  description={`${d.name} — ${d.description.slice(0, 120)}…`}
  structuredData={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pb-16">
    <Breadcrumb crumbs={[
      { label: 'Directory', href: '/directory' },
      { label: 'Groups', href: '/directory/groups' },
      { label: d.name, href: `/directory/groups/${entry.id}` },
    ]} />

    <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-3xl sm:text-4xl font-display text-concrete-900">{d.name}</h1>
        <p class="text-concrete-500 mt-1">
          {d.isOnline ? (
            <span class="text-blue-600 font-medium">🌐 Online Community</span>
          ) : location}
        </p>
      </div>
      {!d.isOnline && <CountryBadge country={d.country} />}
    </div>

    <div class="flex flex-wrap gap-2 mb-6">
      {d.ageRange && (
        <span class="px-3 py-1 text-sm rounded-full bg-skate-orange/10 text-skate-orange border border-skate-orange/30 font-medium">
          {d.ageRange}
        </span>
      )}
      <FeatureBadge label={d.skillLevel} variant="skill" />
    </div>

    {d.meetFrequency && (
      <div class="flex items-start gap-2 mb-6 p-4 bg-concrete-50 rounded-lg border border-concrete-200">
        <span aria-hidden="true" class="text-xl">📅</span>
        <div>
          <p class="text-sm font-medium text-concrete-700">Meeting Schedule</p>
          <p class="text-sm text-concrete-500 mt-0.5">{d.meetFrequency}</p>
        </div>
      </div>
    )}

    <div class="prose prose-concrete max-w-none mb-8">
      <p>{d.description}</p>
      <Content />
    </div>

    <div class="flex flex-wrap gap-3 pt-6 border-t border-concrete-200">
      {d.website && (
        <a href={d.website} target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-skate-orange text-white rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity no-underline min-h-0">
          Visit Website ↗
        </a>
      )}
      {d.facebook && (
        <a href={d.facebook} target="_blank" rel="noopener noreferrer" class="px-4 py-2 border border-concrete-300 text-concrete-600 rounded-lg text-sm font-medium hover:border-concrete-400 transition-colors no-underline min-h-0">
          Facebook Group ↗
        </a>
      )}
      {d.instagram && (
        <a href={`https://instagram.com/${d.instagram}`} target="_blank" rel="noopener noreferrer" class="px-4 py-2 border border-concrete-300 text-concrete-600 rounded-lg text-sm font-medium no-underline min-h-0">
          @{d.instagram}
        </a>
      )}
      {d.discord && (
        <a href={d.discord} target="_blank" rel="noopener noreferrer" class="px-4 py-2 border border-concrete-300 text-concrete-600 rounded-lg text-sm font-medium no-underline min-h-0">
          Discord ↗
        </a>
      )}
      {d.contactEmail && (
        <a href={`mailto:${d.contactEmail}`} class="px-4 py-2 border border-concrete-300 text-concrete-600 rounded-lg text-sm font-medium no-underline min-h-0">
          Email
        </a>
      )}
      <a href="/directory/groups" class="px-4 py-2 text-concrete-500 text-sm hover:text-concrete-700 transition-colors no-underline min-h-0 flex items-center">
        ← All groups
      </a>
    </div>
  </div>
</BaseLayout>
