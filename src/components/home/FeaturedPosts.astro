---
import type { CollectionEntry } from 'astro:content';
import BlogCard from '@components/blog/BlogCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;
---
{posts.length > 0 && (
  <section class="bg-concrete-50 border-t border-concrete-200 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-display text-concrete-800">
          From the Blog
        </h2>
        <a href="/blog" class="text-sm text-skate-orange hover:underline font-medium">
          All posts →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => <BlogCard entry={post} />)}
      </div>
    </div>
  </section>
)}
