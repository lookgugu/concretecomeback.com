---
interface Props {
  parkCount: number;
  shopCount: number;
  groupCount: number;
}
const { parkCount, shopCount, groupCount } = Astro.props;
---
<div class="bg-concrete-100 border-y border-concrete-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6">
    <ul class="flex flex-wrap justify-center gap-8 sm:gap-12 text-center" role="list">
      <li>
        <span class="block text-3xl font-display font-bold text-concrete-800">{parkCount}</span>
        <span class="text-sm text-concrete-500 uppercase tracking-wide">Skate Parks</span>
      </li>
      <li>
        <span class="block text-3xl font-display font-bold text-concrete-800">{shopCount}</span>
        <span class="text-sm text-concrete-500 uppercase tracking-wide">Local Shops</span>
      </li>
      <li>
        <span class="block text-3xl font-display font-bold text-concrete-800">{groupCount}</span>
        <span class="text-sm text-concrete-500 uppercase tracking-wide">Groups</span>
      </li>
      <li>
        <span class="block text-3xl font-display font-bold text-concrete-800">4</span>
        <span class="text-sm text-concrete-500 uppercase tracking-wide">Countries</span>
      </li>
    </ul>
  </div>
</div>
