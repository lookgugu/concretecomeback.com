<section class="bg-concrete-texture relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-concrete-900/60 to-concrete-900/80 pointer-events-none" aria-hidden="true"></div>
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-28 text-center text-white">

    <p class="text-skate-orange font-display text-sm uppercase tracking-widest mb-4">
      For skaters 40+ &amp; 50+
    </p>

    <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold leading-none text-white mb-6">
      You Never Forgot<br class="hidden sm:block" /> How to Ride.
    </h1>

    <p class="text-concrete-200 text-xl sm:text-2xl max-w-2xl mx-auto mb-10 leading-relaxed font-sans font-normal">
      Find adult-friendly skate parks, local shops, and communities of people your age getting back on a board.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/directory/parks"
        class="w-full sm:w-auto px-8 py-4 bg-skate-orange text-white font-display font-bold text-lg rounded-lg hover:opacity-90 transition-opacity shadow-lg min-h-0 no-underline"
      >
        Find a Skate Park
      </a>
      <a
        href="/blog"
        class="w-full sm:w-auto px-8 py-4 bg-white/10 text-white font-semibold text-lg rounded-lg border border-white/30 hover:bg-white/20 transition-colors min-h-0 no-underline"
      >
        Read the Blog
      </a>
    </div>
  </div>
</section>
