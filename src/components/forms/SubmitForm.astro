<form
  action="/api/forms/submit"
  method="POST"
  class="space-y-6"
  id="submit-listing-form"
>
  <!-- Honeypot anti-spam -->
  <input type="text" name="_gotcha" style="display:none" tabindex="-1" aria-hidden="true" autocomplete="off" />

  <!-- Listing type -->
  <fieldset class="space-y-2">
    <legend class="block text-sm font-semibold text-concrete-700 mb-2">What are you submitting? <span class="text-skate-orange">*</span></legend>
    <div class="flex flex-col sm:flex-row gap-3">
      {[
        { value: 'park',  label: '🛹 Skate Park' },
        { value: 'shop',  label: '🏪 Local Shop' },
        { value: 'group', label: '👥 Community Group' },
      ].map(({ value, label }) => (
        <label class="flex items-center gap-2 px-4 py-3 border border-concrete-200 rounded-lg cursor-pointer hover:border-skate-orange transition-colors has-[:checked]:border-skate-orange has-[:checked]:bg-skate-orange/5 flex-1">
          <input type="radio" name="listing-type" value={value} required class="accent-skate-orange" />
          <span class="text-sm font-medium text-concrete-700">{label}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <!-- Common fields -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="sm:col-span-2">
      <label for="f-name" class="block text-sm font-medium text-concrete-700 mb-1">
        Name <span class="text-skate-orange">*</span>
      </label>
      <input
        type="text"
        id="f-name"
        name="name"
        required
        placeholder="Name of the park / shop / group"
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none"
      />
    </div>

    <div>
      <label for="f-city" class="block text-sm font-medium text-concrete-700 mb-1">
        City <span class="text-skate-orange">*</span>
      </label>
      <input
        type="text"
        id="f-city"
        name="city"
        required
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none"
      />
    </div>

    <div>
      <label for="f-country" class="block text-sm font-medium text-concrete-700 mb-1">
        Country <span class="text-skate-orange">*</span>
      </label>
      <select
        id="f-country"
        name="country"
        required
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none bg-white"
      >
        <option value="">Select country…</option>
        <option value="US">🇺🇸 United States</option>
        <option value="UK">🇬🇧 United Kingdom</option>
        <option value="CA">🇨🇦 Canada</option>
        <option value="AU">🇦🇺 Australia</option>
      </select>
    </div>

    <div class="sm:col-span-2">
      <label for="f-website" class="block text-sm font-medium text-concrete-700 mb-1">Website URL</label>
      <input
        type="url"
        id="f-website"
        name="website"
        placeholder="https://"
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none"
      />
    </div>
  </div>

  <!-- Park-specific fields -->
  <div class="park-fields space-y-4 p-4 bg-concrete-50 rounded-lg border border-concrete-200">
    <h3 class="font-display text-sm text-concrete-700 uppercase tracking-wide">Park Details</h3>
    <div>
      <label for="f-difficulty" class="block text-sm font-medium text-concrete-700 mb-1">Difficulty Level</label>
      <select id="f-difficulty" name="difficulty" class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm bg-white focus:border-skate-orange focus:outline-none">
        <option value="">Select…</option>
        <option value="beginner-friendly">Beginner Friendly</option>
        <option value="mixed">Mixed</option>
        <option value="intermediate">Intermediate</option>
        <option value="advanced">Advanced</option>
      </select>
    </div>
    <div>
      <label class="flex items-center gap-2 text-sm text-concrete-700 cursor-pointer">
        <input type="checkbox" name="adult-friendly" value="yes" class="accent-skate-orange w-4 h-4" />
        This park is welcoming to adult skaters (40+)
      </label>
    </div>
    <div>
      <label for="f-entry-fee" class="block text-sm font-medium text-concrete-700 mb-1">Entry Fee</label>
      <input type="text" id="f-entry-fee" name="entry-fee" placeholder="e.g. Free, £3/session, $5"
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none" />
    </div>
  </div>

  <!-- Shop-specific fields -->
  <div class="shop-fields space-y-4 p-4 bg-concrete-50 rounded-lg border border-concrete-200">
    <h3 class="font-display text-sm text-concrete-700 uppercase tracking-wide">Shop Details</h3>
    <div>
      <label for="f-instagram" class="block text-sm font-medium text-concrete-700 mb-1">Instagram handle</label>
      <input type="text" id="f-instagram" name="instagram" placeholder="@yourshop"
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none" />
    </div>
    <div>
      <label class="flex items-center gap-2 text-sm text-concrete-700 cursor-pointer">
        <input type="checkbox" name="adult-advice" value="yes" class="accent-skate-orange w-4 h-4" />
        Staff offer specific advice for returning adult skaters
      </label>
    </div>
  </div>

  <!-- Group-specific fields -->
  <div class="group-fields space-y-4 p-4 bg-concrete-50 rounded-lg border border-concrete-200">
    <h3 class="font-display text-sm text-concrete-700 uppercase tracking-wide">Group Details</h3>
    <div>
      <label for="f-age-range" class="block text-sm font-medium text-concrete-700 mb-1">Age Range</label>
      <input type="text" id="f-age-range" name="age-range" placeholder="e.g. 40+, 35-60, All welcome"
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none" />
    </div>
    <div>
      <label for="f-meet-frequency" class="block text-sm font-medium text-concrete-700 mb-1">Meeting Schedule</label>
      <input type="text" id="f-meet-frequency" name="meet-frequency" placeholder="e.g. Every Sunday 9am–noon"
        class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none" />
    </div>
    <div>
      <label class="flex items-center gap-2 text-sm text-concrete-700 cursor-pointer">
        <input type="checkbox" name="is-online" value="yes" class="accent-skate-orange w-4 h-4" />
        This is an online-only community (no in-person meetups)
      </label>
    </div>
  </div>

  <!-- Description -->
  <div>
    <label for="f-description" class="block text-sm font-medium text-concrete-700 mb-1">
      Description <span class="text-skate-orange">*</span>
    </label>
    <textarea
      id="f-description"
      name="description"
      rows={4}
      required
      placeholder="Tell us about this park / shop / group in a few sentences."
      class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none resize-y"
    ></textarea>
  </div>

  <!-- Submitter email -->
  <div>
    <label for="f-email" class="block text-sm font-medium text-concrete-700 mb-1">
      Your email <span class="text-concrete-400 font-normal">(optional — we'll notify you when it's listed)</span>
    </label>
    <input
      type="email"
      id="f-email"
      name="email"
      placeholder="you@example.com"
      class="w-full px-3 py-2 border border-concrete-200 rounded-lg text-sm focus:border-skate-orange focus:outline-none"
    />
  </div>

  <button
    type="submit"
    class="w-full sm:w-auto px-8 py-3 bg-skate-orange text-white font-bold font-display rounded-lg hover:opacity-90 transition-opacity cursor-pointer border-0"
  >
    Submit for Review
  </button>

  <p class="text-xs text-concrete-400">
    All submissions are manually reviewed before being added to the directory. We aim to review within 5 business days.
  </p>
</form>
