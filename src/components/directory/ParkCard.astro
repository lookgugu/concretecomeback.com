---
import type { CollectionEntry } from 'astro:content';
import CountryBadge from './CountryBadge.astro';
import FeatureBadge from './FeatureBadge.astro';

interface Props {
  entry: CollectionEntry<'parks'>;
}
const { entry } = Astro.props;
const { name, country, city, stateProvince, difficulty, adultFriendly, surface, features, entryFee, heroImage, heroImageAlt, isIndoor } = entry.data;

const location = stateProvince ? `${city}, ${stateProvince}` : city;
const maxFeatures = 4;
const extraFeatures = features.length - maxFeatures;

// data attributes are emitted as lowercase for filter script
const dataAttrs = {
  'data-country': country,
  'data-features': features.join(' '),
  'data-surface': surface.join(' '),
  'data-difficulty': difficulty,
  'data-adult': String(adultFriendly),
  'data-name': name.toLowerCase(),
  'data-city': city.toLowerCase(),
  'data-indoor': String(isIndoor),
};
---
<article
  class="bg-white border border-concrete-200 rounded-xl overflow-hidden shadow-card hover:shadow-card-hover hover:border-concrete-300 transition-all flex flex-col"
  {...dataAttrs}
>
  {heroImage && (
    <a href={`/directory/parks/${entry.id}`} class="block overflow-hidden min-h-0 min-w-0 no-underline" tabindex="-1" aria-hidden="true">
      <img
        src={heroImage}
        alt={heroImageAlt ?? name}
        class="w-full h-40 object-cover hover:scale-105 transition-transform duration-300"
        loading="lazy"
        width="400"
        height="160"
      />
    </a>
  )}

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-display text-lg text-concrete-900 leading-snug">
        <a href={`/directory/parks/${entry.id}`} class="hover:text-skate-orange transition-colors no-underline">
          {name}
        </a>
      </h3>
      <CountryBadge country={country} />
    </div>

    <p class="text-sm text-concrete-500 mb-3">{location}</p>

    <div class="flex flex-wrap gap-1.5 mb-3">
      <FeatureBadge label={difficulty} variant="difficulty" />
      {surface.slice(0, 2).map((s) => <FeatureBadge label={s} variant="surface" />)}
    </div>

    <div class="flex flex-wrap gap-1 mb-3">
      {features.slice(0, maxFeatures).map((f) => <FeatureBadge label={f} />)}
      {extraFeatures > 0 && (
        <span class="px-2 py-0.5 text-xs rounded-full bg-concrete-100 text-concrete-400 border border-concrete-200">
          +{extraFeatures} more
        </span>
      )}
    </div>

    <div class="mt-auto flex items-center justify-between text-sm">
      <div class="flex items-center gap-2">
        {adultFriendly && (
          <span class="flex items-center gap-1 text-skate-green font-medium text-xs">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
              <path d="M6 0a6 6 0 1 1 0 12A6 6 0 0 1 6 0Zm2.78 4.22a.75.75 0 0 0-1.06 0L5.25 6.69l-.97-.97a.75.75 0 0 0-1.06 1.06l1.5 1.5a.75.75 0 0 0 1.06 0l3-3a.75.75 0 0 0 0-1.06Z"/>
            </svg>
            Adult Friendly
          </span>
        )}
        {isIndoor && <span class="text-xs text-concrete-400">Indoor</span>}
      </div>
      {entryFee && (
        <span class="text-xs text-concrete-500 font-medium">{entryFee}</span>
      )}
    </div>
  </div>
</article>
