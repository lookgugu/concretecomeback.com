---
export interface Props {
  title: string;
  description: string;
  canonicalURL?: URL | string;
  ogImage?: string;
  type?: 'website' | 'article' | 'place';
  structuredData?: object | object[];
  noIndex?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
}

const {
  title,
  description,
  canonicalURL = Astro.url,
  ogImage = '/og-default.jpg',
  type = 'website',
  structuredData,
  noIndex = false,
  pubDate,
  updatedDate,
  author,
} = Astro.props;

const siteTitle = 'Concrete Comeback';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonicalStr = canonicalURL.toString().split('?')[0];
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `https://concretecomeback.com${ogImage}`;

const allStructuredData = Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [];
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#1a1512" />

<title>{fullTitle}</title>
<meta name="description" content={description} />
{noIndex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonicalStr} />

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalStr} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbs} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={siteTitle} />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
{author && <meta property="article:author" content={author} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbs} />

<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Oswald:wght@700&display=swap" />

{allStructuredData.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
))}
