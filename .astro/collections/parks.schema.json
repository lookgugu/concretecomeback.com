{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "country": {
      "type": "string",
      "enum": [
        "US",
        "UK",
        "CA",
        "AU"
      ]
    },
    "stateProvince": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "coordinates": {
      "type": "object",
      "properties": {
        "lat": {
          "type": "number"
        },
        "lng": {
          "type": "number"
        }
      },
      "required": [
        "lat",
        "lng"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 50
    },
    "surface": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "concrete",
          "wood",
          "asphalt",
          "hybrid",
          "tiles"
        ]
      }
    },
    "features": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "bowl",
          "pool",
          "street",
          "ramps",
          "rails",
          "stairs",
          "flatground",
          "pump-track",
          "banks",
          "transitions",
          "mini-ramp",
          "vert",
          "flow-section"
        ]
      }
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "beginner-friendly",
        "mixed",
        "intermediate",
        "advanced"
      ]
    },
    "adultFriendly": {
      "type": "boolean"
    },
    "hasLighting": {
      "type": "boolean"
    },
    "hasParking": {
      "type": "boolean"
    },
    "hasToilets": {
      "type": "boolean"
    },
    "isCovered": {
      "type": "boolean"
    },
    "isIndoor": {
      "default": false,
      "type": "boolean"
    },
    "openingHours": {
      "type": "string"
    },
    "entryFee": {
      "type": "string"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "googleMapsUrl": {
      "type": "string",
      "format": "uri"
    },
    "heroImage": {
      "type": "string"
    },
    "heroImageAlt": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "addedDate": {
      "type": "string",
      "format": "date-time"
    },
    "lastVerified": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "country",
    "city",
    "description",
    "surface",
    "features",
    "difficulty",
    "adultFriendly",
    "addedDate"
  ]
}