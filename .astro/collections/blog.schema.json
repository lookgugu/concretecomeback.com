{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "minLength": 50,
      "maxLength": 165
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": "string"
    },
    "authorAge": {
      "type": "integer",
      "minimum": 30,
      "maximum": 80
    },
    "authorBio": {
      "type": "string",
      "maxLength": 200
    },
    "tags": {
      "minItems": 1,
      "maxItems": 8,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "heroImage": {
      "type": "string"
    },
    "heroImageAlt": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "author",
    "tags"
  ]
}